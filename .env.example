# ==============================================================================
# RecettesBot — Environment Configuration
# ==============================================================================
#
# Copy this file to `.env` and fill in the required values.
#
#   cp .env.example .env
#
# WARNING: Never commit `.env` to version control — it contains secrets.
#
# Legend:
#   [required]  — must be set; the application will not start without it
#   [optional]  — has a sensible default; override only when needed
#
# ==============================================================================


# ------------------------------------------------------------------------------
# Deployment (Ansible)  [local-only — not sent to the server]
# ------------------------------------------------------------------------------

HOST_IP=192.168.1.100
HOST_USER=username
HOST_SSH_PRIVATE_KEY_FILE=~/.ssh/privatekeyfile


# ------------------------------------------------------------------------------
# Telegram Bot  [required]
# ------------------------------------------------------------------------------

# Bot token obtained from @BotFather (https://t.me/BotFather).
TELEGRAM_BOT_TOKEN=


# ------------------------------------------------------------------------------
# Anthropic / Claude SDK  [required]
# ------------------------------------------------------------------------------

# API key from https://console.anthropic.com/. Read directly by the SDK at
# runtime (not via Pydantic Settings). If left empty in a Docker deployment,
# the entrypoint falls back to a credentials file mounted at
# /mnt/claude-credentials/.credentials.json (see CLAUDE_CREDENTIALS_FILE).
ANTHROPIC_API_KEY=

# Host path to a Claude Code credentials file (`.credentials.json`). Used only
# when ANTHROPIC_API_KEY is empty; the entrypoint copies this file into the
# container's home directory so the Claude Agent SDK can authenticate.
# Leave unset to disable the mount (a harmless /dev/null default is substituted).
# Typical value on Linux/macOS hosts:
#   CLAUDE_CREDENTIALS_FILE=${HOME}/.claude/.credentials.json
# CLAUDE_CREDENTIALS_FILE=


# ------------------------------------------------------------------------------
# PostgreSQL Database  [optional — defaults shown]
# ------------------------------------------------------------------------------

# POSTGRES_HOST and POSTGRES_PORT are determined by the Docker Compose service
# definition and should not be overridden here.

POSTGRES_DB=rb_db
POSTGRES_USER=rb_user
# SECURITY: Change this value in production.
POSTGRES_PASSWORD=changeme


# ------------------------------------------------------------------------------
# Hugging Face Hub  [optional]
# ------------------------------------------------------------------------------

# Personal access token from https://huggingface.co/settings/tokens.
# When set, sentence-transformers downloads the embedding model via
# authenticated requests, which unlocks higher rate limits and faster
# downloads. Leave commented out or blank for anonymous access.
# HF_TOKEN=


# ------------------------------------------------------------------------------
# Embedding Model  [optional — default shown]
# ------------------------------------------------------------------------------

# HuggingFace Sentence Transformers model used to generate recipe title
# embeddings for semantic search.
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2


# ------------------------------------------------------------------------------
# Semantic Search Tuning  [optional — defaults shown]
# ------------------------------------------------------------------------------

# Minimum cosine-similarity score (0.0–1.0) for a recipe to be considered a
# match. Lower values return more results; higher values are stricter.
SEARCH_DISTANCE_THRESHOLD=0.65

# Maximum number of recipes returned per search query.
SEARCH_RESULT_LIMIT=5


# ------------------------------------------------------------------------------
# Agent Execution  [optional — default shown]
# ------------------------------------------------------------------------------

# Maximum wall-clock seconds the Claude agent is allowed when extracting a
# recipe from a URL before the request is cancelled.
AGENT_TIMEOUT_SECONDS=120


# ------------------------------------------------------------------------------
# Observability  [optional]
# ------------------------------------------------------------------------------

# Pydantic Logfire token for tracing and monitoring.
# Leave commented out or blank to disable Logfire instrumentation.
# LOGFIRE_TOKEN=


# ------------------------------------------------------------------------------
# Access Control  [optional — empty = open to everyone]
# ------------------------------------------------------------------------------

# Restrict bot usage to specific Telegram users or groups. Each variable
# accepts a comma-separated list of integer IDs (e.g., "123456789,987654321").
# When both are empty (or commented out), the bot is open to everyone.

# ALLOWED_USER_IDS=
# ALLOWED_GROUP_IDS=
